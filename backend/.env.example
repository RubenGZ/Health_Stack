# =============================================================================
# backend/.env.example — Variables de la aplicación FastAPI
# Copia como: cp backend/.env.example backend/.env
# En la Pi el script setup-pi.sh genera este archivo automáticamente.
# =============================================================================

APP_ENV=production
DEBUG=false

# Base de datos (docker-compose.pi.yml sobreescribe estas con el nombre del servicio)
DATABASE_URL=postgresql+asyncpg://postgres:POSTGRES_PASSWORD@postgres:5432/healthstack
DATABASE_SYNC_URL=postgresql://postgres:POSTGRES_PASSWORD@postgres:5432/healthstack

# Cifrado AES-256 de datos biométricos (RGPD Art. 32)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️  NO CAMBIAR después del primer arranque — perderías todos los datos de salud
HEALTH_LINK_MASTER_KEY=GENERAR_CON_OPENSSL

# JWT RS256 — generar con setup-pi.sh o manualmente:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Reemplaza los saltos de línea con \n para meterlo en una sola línea
JWT_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nTU_CLAVE_PUBLICA_AQUI\n-----END PUBLIC KEY-----
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — dominio público que sirve el frontend (tu túnel de Cloudflare)
ALLOWED_ORIGINS=https://TU-SUBDOMINIO.TU-DOMINIO.COM

# Redis (no usado en Pi básico, dejar por defecto)
REDIS_URL=redis://localhost:6379/0

# APIs externas (opcionales)
GROK_API_KEY=
SENTRY_DSN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
