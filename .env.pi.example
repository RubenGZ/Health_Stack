# =============================================================================
# .env.pi — Variables para docker-compose.pi.yml (proyecto raíz)
# Copia como: cp .env.pi.example .env.pi
# Luego carga con: set -a && source .env.pi && set +a
# O pásalo a compose: docker compose --env-file .env.pi -f docker-compose.pi.yml up -d
# =============================================================================

# Contraseñas de servicios (generar con: openssl rand -hex 16)
POSTGRES_PASSWORD=CAMBIA_ESTO
REDIS_PASSWORD=CAMBIA_ESTO

# Cloudflare Tunnel token
# Obtenerlo en: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Crea el tunnel, apúntalo a http://nginx:80 y copia el token aquí
CLOUDFLARE_TUNNEL_TOKEN=PEGA_TU_TOKEN_AQUI
