# ============================================================
# HealthStack Pro V2 — Variables de Entorno
# NUNCA commitear el archivo .env real al repositorio.
# Copiar este archivo como .env y rellenar los valores.
# ============================================================

# --- Base de datos ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/healthstack
# Para Alembic (sync driver):
DATABASE_SYNC_URL=postgresql://user:password@localhost:5432/healthstack

# --- Seguridad: Llave de Cruce (AEPD / Art. 32 RGPD) ---
# CRÍTICO: Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# Debe ser exactamente 64 caracteres hex (= 32 bytes = 256 bits para AES-256)
# Esta clave NUNCA va a la base de datos. Solo existe en el entorno de ejecución.
HEALTH_LINK_MASTER_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# --- JWT (RS256 — clave asimétrica) ---
# Generar par de claves:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Luego poner el contenido PEM aquí (con \n para saltos de línea)
JWT_PRIVATE_KEY_PEM=CHANGE_ME
JWT_PUBLIC_KEY_PEM=CHANGE_ME
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Aplicación ---
APP_ENV=development         # development | staging | production
APP_SECRET_KEY=CHANGE_ME    # Para firmar cookies, CSRF, etc.
DEBUG=true

# --- Sentry (Observabilidad) ---
SENTRY_DSN=                 # Dejar vacío en desarrollo

# --- Redis (Rate limiting, caché de tokens revocados) ---
REDIS_URL=redis://localhost:6379/0
